<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#000000">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="边框流光效果"
        android:textSize="24sp"
        android:textColor="#FFFFFF"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <com.evenbus.view.light.BorderLightView_1
        android:id="@+id/border_light_view"
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="32dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#333333"
        android:padding="16dp">

        <TextView
            android:id="@+id/text_arc_width"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="光弧宽度: 60°"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/seekbar_arc_width"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="180"
            android:progress="60"/>

        <TextView
            android:id="@+id/text_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="旋转速度: 30"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

        <SeekBar
            android:id="@+id/seekbar_speed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="30"/>

        <Button
            android:id="@+id/btn_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="停止动画"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"/>

        <Button
            android:id="@+id/btn_gradient_demo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="查看渐变效果演示"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>

</LinearLayout>